# Gradle files and build outputs
.gradle/
build/
/*/build/
app/build/

# Local configuration file (specific to each machine, like Android SDK path)
local.properties

# Log Files
*.log

# Proguard folder generated by Gradle
/proguard/

# Device Schema & Captures
/captures/

# Android Studio / IntelliJ IDEA local configuration files
.idea/workspace.xml
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/deploymentTargetSelector.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/kotlinc.xml
.idea/shelf/
.idea/scopes/
.idea/gradle.xml
.idea/misc.xml
.idea/vcs.xml

# IntelliJ IDEA project files
*.iml
*.ipr
*.iws

# Javac compiler outputs
*.class

# Keystore files (for app signing - should never be committed for security)
*.jks
*.keystore

# External native builds (C/C++ integration)
.externalNativeBuild/
.cxx/

# OS-generated files
.DS_Store
Thumbs.db
